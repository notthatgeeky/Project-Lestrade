{
  "test_case_id": "tc_003_rename_midcall",
  "description": "Candidate joins as 'User 1', speaks, then renames to 'Aarav Sharma' midway through. Roster tracking should update metadata and boost confidence.",
  "expected_candidate_participant_idx": 1,
  "interview_metadata": {
    "expected_candidate_name": "Aarav Sharma"
  },
  "events": [
    {
      "timestamp_ms": 1000,
      "type": "PARTICIPANT_JOIN",
      "participant_idx": 0,
      "payload": {
        "display_name": "Sarah Chen (Interviewer)",
        "camera_on": true
      }
    },
    {
      "timestamp_ms": 5000,
      "type": "PARTICIPANT_JOIN",
      "participant_idx": 1,
      "payload": {
        "display_name": "User 1",
        "camera_on": true
      }
    },
    {
      "timestamp_ms": 10000,
      "type": "SPEAKING_START",
      "participant_idx": 0
    },
    {
      "timestamp_ms": 20000,
      "type": "SPEAKING_STOP",
      "participant_idx": 0
    },
    {
      "timestamp_ms": 21000,
      "type": "TRANSCRIPT_CHUNK",
      "participant_idx": 0,
      "payload": {
        "speaker_name": "Sarah Chen (Interviewer)",
        "text": "Hi there. Can you introduce yourself? You're currently named User 1."
      }
    },
    {
      "timestamp_ms": 25000,
      "type": "SPEAKING_START",
      "participant_idx": 1
    },
    {
      "timestamp_ms": 55000,
      "type": "SPEAKING_STOP",
      "participant_idx": 1
    },
    {
      "timestamp_ms": 56000,
      "type": "TRANSCRIPT_CHUNK",
      "participant_idx": 1,
      "payload": {
        "speaker_name": "User 1",
        "text": "Hi Sarah! Yes, sorry about that. My name is Aarav Sharma. I will rename myself in a second. I am a backend software engineer."
      }
    },
    {
      "timestamp_ms": 60000,
      "type": "PARTICIPANT_RENAME",
      "participant_idx": 1,
      "payload": {
        "new_name": "Aarav Sharma"
      }
    },
    {
      "timestamp_ms": 65000,
      "type": "SPEAKING_START",
      "participant_idx": 0
    },
    {
      "timestamp_ms": 75000,
      "type": "SPEAKING_STOP",
      "participant_idx": 0
    },
    {
      "timestamp_ms": 76000,
      "type": "TRANSCRIPT_CHUNK",
      "participant_idx": 0,
      "payload": {
        "speaker_name": "Sarah Chen (Interviewer)",
        "text": "Thanks Aarav, got it. Let's talk about your experience with systems design."
      }
    },
    {
      "timestamp_ms": 80000,
      "type": "SPEAKING_START",
      "participant_idx": 1
    },
    {
      "timestamp_ms": 180000,
      "type": "SPEAKING_STOP",
      "participant_idx": 1
    },
    {
      "timestamp_ms": 181000,
      "type": "TRANSCRIPT_CHUNK",
      "participant_idx": 1,
      "payload": {
        "speaker_name": "Aarav Sharma",
        "text": "For systems design, I focus on scalability and reliability. I designed our core indexing flow at my last company, where we migrated from single instances to a highly available cluster."
      }
    }
  ]
}
